{
  "uid": "admin-overview",
  "title": "Admin Service Overview",
  "tags": ["admin"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    { "id": 1, "title": "Operator Actions", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(admin_actions_performed_total[5m])) by (action)", "legendFormat": "{{action}}", "refId": "A" }]
    },
    { "id": 2, "title": "Lock / Unlock Count", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(admin_lock_total[5m])", "refId": "A", "legendFormat": "lock" },
        { "expr": "rate(admin_unlock_total[5m])", "refId": "B", "legendFormat": "unlock" }
      ]
    },
    { "id": 3, "title": "Audit Queries", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(admin_audit_queries_total[5m])", "refId": "A" }]
    },
    { "id": 4, "title": "Downstream Failures", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(admin_downstream_failures_total[5m])", "refId": "A" }]
    },
    { "id": 5, "title": "Audit Trail Rate", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(admin_audit_trail_total[5m])", "refId": "A" }]
    },
    { "id": 6, "title": "Role Breakdown", "type": "piechart", "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(admin_actions_performed_total[5m])) by (role)", "legendFormat": "{{role}}", "refId": "A" }]
    },
    { "id": 7, "title": "Reason-Required Rejections", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(admin_reason_required_rejected_total[5m])", "refId": "A" }]
    },
    { "id": 8, "title": "4xx / 5xx", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{service=\"admin-service\",status=~\"4..\"}[5m]))", "refId": "A", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_server_requests_seconds_count{service=\"admin-service\",status=~\"5..\"}[5m]))", "refId": "B", "legendFormat": "5xx" }
      ]
    },
    { "id": 9, "title": "Latency p99", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{service=\"admin-service\"}[5m])) by (le))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
