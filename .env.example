# =============================================================================
# Global Account Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Default values are set so that `docker compose up -d` works without .env.
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT=3306

# --- MySQL Service User Passwords ---
AUTH_DB_PASSWORD=auth_pass
ACCOUNT_DB_PASSWORD=account_pass
SECURITY_DB_PASSWORD=security_pass
ADMIN_DB_PASSWORD=admin_pass

# --- Redis ---
REDIS_PASSWORD=redispass
REDIS_PORT=6379

# --- Kafka (KRaft) ---
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg
KAFKA_EXTERNAL_PORT=9093

# --- Kafka UI ---
KAFKA_UI_PORT=8090
